# Specifies intentionally untracked files to ignore when using Git
# http://git-scm.com/docs/gitignore

target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

### IntelliJ IDEA ###
*.idea/
*.iws
*.iml
*.ipr
*.mvn
*.idea*

### VS Code ###
*.vscode/
*.sln
obj/
bin/
*lib/
*lib/*
*.csproj



